{
  "name": "@axiomorix/axql-core",
  "version": "0.1.0",
  "description": "A small, safe, embeddable expression engine for Axiomorix systems.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "bun test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "smoke": "bun run build && bun test smoke/*.test.ts",
    "demo": "vite --config vite.config.ts",
    "demo:build": "vite build --config vite.config.ts",
    "demo:typecheck": "tsc -p demo/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.8.0",
    "vite": "^7.1.0"
  }
}
